<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Gebelik Haftası Hesaplayıcı</title>
</head>
<body>
    <h1>Gebelik Haftası Hesaplayıcı</h1>

    <label for="lastPeriod">Son adet tarihi:</label>
    <input type="date" id="lastPeriod">
    <button onclick="calculateWeek()">Hesapla</button>
    <p id="result"></p>

    <script>
        function calculateWeek() {
            const lastPeriod = new Date(document.getElementById("lastPeriod").value);
            const today = new Date();
            const diffTime = today - lastPeriod; // ms
            const diffDays = diffTime / (1000*60*60*24);
            const week = Math.floor(diffDays / 7);
            document.getElementById("result").innerText = "Hamilelik haftası: " + week;
        }
    </script>
</body>
</html>
